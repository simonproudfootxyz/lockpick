# Neon Postgres (https://neon.tech)
# Pooled connection — use for app runtime (Railway, local dev)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require

# Direct connection — use for Drizzle migrations only
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-random-secret
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Optional — Google SSO (future)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
